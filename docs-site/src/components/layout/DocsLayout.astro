---
import Sidebar from "./Sidebar.astro";
import "../../styles/global.css";

const {
  title = "wegotthis.online Docs",
  description = "Internal documentation website for product and technical architecture maps.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="min-h-screen bg-[var(--page-bg)] text-[var(--text-body)]">
      <div class="grid min-h-screen lg:grid-cols-[290px_minmax(0,1fr)]">
        <Sidebar currentPath={Astro.url.pathname} />

        <main class="min-w-0">
          <div class="mx-auto max-w-[88rem] px-5 py-6 md:px-8 md:py-8">
            <slot />
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
