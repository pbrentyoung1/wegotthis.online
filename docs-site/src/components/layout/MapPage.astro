---
const {
  eyebrow = "Architecture Map",
  title,
  purpose,
  status,
  coreRules = [],
  relationships = [],
  openQuestions = [],
  expectedQuestions = [],
  relatedMaps = [],
} = Astro.props;
---

<div class="space-y-6">
  <section class="docs-card p-6 md:p-8">
    <p class="eyebrow">{eyebrow}</p>
    <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="max-w-3xl">
        <h1 class="docs-display text-3xl font-semibold tracking-tight text-[var(--text-strong)] md:text-4xl">{title}</h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-[var(--text-muted)] md:text-lg">
          {purpose}
        </p>
      </div>

      {
        status && (
          <div class="docs-card-soft px-4 py-3 text-sm shadow-[var(--shadow-1)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--accent-blue)]">Status</p>
            <p class="mt-2 font-medium text-[var(--text-strong)]">{status}</p>
          </div>
        )
      }
    </div>
  </section>

  <section class="docs-card p-4 md:p-6">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="section-title">Visual Diagram</h2>
      <p class="text-sm text-[var(--text-muted)]">Use this view as the first shared mental model.</p>
    </div>
    <div class="overflow-hidden rounded-[1.25rem] border border-[var(--border-soft)] bg-[var(--surface-soft)]">
      <slot name="diagram" />
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="docs-card p-6">
      <h2 class="section-title">Core Rules</h2>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-[var(--text-body)] md:text-[15px]">
        {coreRules.map((rule) => <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--accent-blue)]"></span><span>{rule}</span></li>)}
      </ul>
    </section>

    <section class="docs-card p-6">
      <h2 class="section-title">Relationships</h2>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-[var(--text-body)] md:text-[15px]">
        {relationships.map((item) => <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--accent-coral)]"></span><span>{item}</span></li>)}
      </ul>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
    <section class="docs-card p-6">
      <h2 class="section-title">{expectedQuestions.length > 0 ? "Expected Questions" : "Open Questions"}</h2>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-[var(--text-body)] md:text-[15px]">
        {(expectedQuestions.length > 0 ? expectedQuestions : openQuestions).map((item) => (
          <li class="flex gap-3">
            <span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--accent-blue)]"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="docs-card p-6">
      <h2 class="section-title">Related Maps</h2>
      <div class="mt-4 space-y-3">
        {relatedMaps.map((map) => (
          <a href={map.href} class="block rounded-2xl border border-[var(--border-soft)] bg-[var(--surface-soft)] px-4 py-3 text-sm font-medium text-[var(--text-strong)] transition hover:border-[var(--accent-blue)] hover:text-[var(--accent-blue)]">
            {map.label}
          </a>
        ))}
      </div>
    </section>
  </div>
</div>
