---
import DocsLayout from "../../components/layout/DocsLayout.astro";

const corePalette = [
  { name: "Slate", hex: "#6b7280", usage: "Primary structural color, interactive elements, calm emphasis, and secondary text." },
  { name: "Terracotta", hex: "#b65e3c", usage: "Warmth, conversational energy, creative accents, and editorial highlights." },
  { name: "Olive", hex: "#848e6c", usage: "Collaboration, growth, steady support, and ministry depth." },
  { name: "Warm Canvas", hex: "#f7f4ee", usage: "Primary page background and workspace atmosphere." },
  { name: "Surface", hex: "#ffffff", usage: "Cards, forms, panels, and readable focus areas." },
  { name: "Light Gray", hex: "#d6d2c8", usage: "Dividers, borders, subtle panels, and quiet structural separation." },
  { name: "Primary Text", hex: "#1c1c1e", usage: "Headlines, strong labels, readable interface text, and the ForWorship mark." },
  { name: "Secondary Text", hex: "#6b7280", usage: "Supporting copy, metadata, and softer instructional text." },
];

const supportingPalette = [
  { name: "Gold", hex: "#BFA052", usage: "Encouragement, highlights, celebratory moments, and warm callouts.", role: "Worn brass, mature warmth. Hopeful without being bright." },
  { name: "Mauve", hex: "#7a5c63", usage: "Reflective moments, emotional depth, storytelling, and occasional editorial accents.", role: "Richness, reflection, and emotional intelligence." },
  { name: "Dark Canvas", hex: "#2a2a2d", usage: "Dark mode page background and base surface.", role: "Warm charcoal without blue cast. Not pure black." },
];

const semanticCards = [
  {
    label: "Success",
    tone: "Use Olive",
    className: "border-[var(--accent-forest-border)] bg-[var(--accent-forest-soft)]",
    chipClass: "bg-[var(--accent-forest)] text-white",
    body: "Upload complete. Everything is in place and ready for the next step.",
  },
  {
    label: "Warning",
    tone: "Use Gold + Terracotta",
    className: "border-[var(--accent-gold-border)] bg-[var(--accent-gold-soft)]",
    chipClass: "bg-[var(--accent-gold)] text-[var(--text-strong)]",
    body: "We still need one date before this can move forward cleanly.",
  },
  {
    label: "Error",
    tone: "Use Muted Brick only when needed",
    className: "border-[var(--accent-brick-border)] bg-[var(--accent-brick-soft)]",
    chipClass: "bg-[var(--color-muted-brick)] text-white",
    body: "Something did not go through. Try again and we'll get it sorted.",
  },
  {
    label: "Information",
    tone: "Use Slate",
    className: "border-[var(--accent-sky-border)] bg-[var(--accent-sky-soft)]",
    chipClass: "bg-[var(--accent-sky)] text-white",
    body: "This request looks similar to last month's event. Want to reuse that structure?",
  },
];

const accentExamples = [
  { name: "Gold", className: "border-[var(--accent-gold-border)] bg-[var(--accent-gold-soft)]", title: "Encouragement", copy: "You're closer than it feels. Two approvals are already done." },
  { name: "Terracotta", className: "border-[var(--accent-coral-border)] bg-[var(--accent-coral-soft)]", title: "Creative Warmth", copy: "Start with what you know and we'll shape the rest together." },
  { name: "Olive", className: "border-[var(--accent-forest-border)] bg-[var(--accent-forest-soft)]", title: "Grounded Progress", copy: "Everything needed for scheduling is now in place." },
  { name: "Mauve", className: "border-[var(--accent-plum-border)] bg-[var(--accent-plum-soft)]", title: "Reflective Note", copy: "This is a good place to preserve what worked for next season." },
  { name: "Light Gray", className: "border-[var(--color-soft-fog)] bg-[var(--color-soft-fog)]/20", title: "Quiet Structure", copy: "Use this for panels, dividers, hover states, and gentle framing." },
];

const spacing = [8, 12, 16, 24, 32, 48, 64];

const radii = [
  { label: "Buttons", value: "10px", className: "rounded-[10px]" },
  { label: "Inputs", value: "12px", className: "rounded-[12px]" },
  { label: "Cards", value: "16px", className: "rounded-[16px]" },
  { label: "Modals", value: "20px", className: "rounded-[20px]" },
  { label: "Floating Panels", value: "24px", className: "rounded-[24px]" },
];

const shadows = [
  { name: "shadow-1", value: "0 1px 2px rgba(15, 23, 42, 0.04)", style: "box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);" },
  { name: "shadow-2", value: "0 4px 12px rgba(15, 23, 42, 0.06)", style: "box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);" },
  { name: "shadow-3", value: "0 12px 32px rgba(15, 23, 42, 0.10)", style: "box-shadow: 0 12px 32px rgba(15, 23, 42, 0.10);" },
];
---

<DocsLayout
  title="Visual System | ForWorship Creative Docs"
  description="Visual brand system for the calm editorial workspace direction."
>
  <div class="space-y-6">
    <section class="docs-card p-8 md:p-10">
      <p class="eyebrow">Visual System</p>
      <div class="mt-4 max-w-4xl">
        <h1 class="text-4xl tracking-tight text-[var(--text-strong)] md:text-5xl" style="font-family: var(--font-serif);">
          Calm Editorial Workspace
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-[var(--text-muted)]">
          ForWorship Creative inherits the ForWorship ecosystem brand fully. The system should feel like a calm, capable teammate in visual form: clear, warm, steady, and ready to help without becoming loud, cold, or managerial.
        </p>
        <div class="mt-6 rounded-[24px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-6" style="box-shadow: var(--shadow-2);">
          <p class="text-sm leading-relaxed text-[var(--text-body)]" style="font-family: var(--font-serif);">
            "The interface should feel like a thoughtfully designed creative workspace before the team arrives: morning light, calm order, quiet readiness, and the sense that someone capable is already helping."
          </p>
        </div>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="eyebrow">Brand Feeling</p>
          <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
            Calm, support, clarity, warmth, confidence, collaboration
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed text-[var(--text-muted)]">
          The system should avoid dense enterprise dashboards, harsh admin UI, church clipart energy, productivity-bro aesthetics, overhyped startup styling, and gimmicky AI visuals.
        </p>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Logo and Mark</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        One mark, one brand
      </h2>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--text-muted)]">
        ForWorship Creative fully inherits the ForWorship ecosystem brand. The mark is a speech bubble combined with a play button: communication and ministry production in one icon. No module-level visual differentiation — every ForWorship product shares this identity.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-6" style="box-shadow: var(--shadow-1);">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--text-muted)]">Mark — Light Background</p>
          <div class="mt-4 flex items-center gap-4">
            <svg class="h-10 w-auto shrink-0" fill="#1c1c1e" viewBox="0 0 155 159" xmlns="http://www.w3.org/2000/svg" aria-label="ForWorship mark">
              <path d="M81.75,0c26.54,2.56,50,18.25,61.69,41.76,13.03,26.19,10.03,56.63-7.1,79.62l5.9,33.47c.35,1.99-1.31,3.09-2.45,4.15h-2.55l-33.92-12.5c-23.51,9.02-49.37,6.22-70.42-8.1C14.21,125.68,2.2,104.73,0,81.75v-12C3.78,32.19,32.19,3.73,69.75,0h12ZM138.28,75.7c0-34.34-27.84-62.18-62.18-62.18S13.93,41.36,13.93,75.7s27.84,62.18,62.18,62.18,62.18-27.84,62.18-62.18Z"/>
              <path d="M112.18,79.73l-49.5,28.35c-1.35.77-3.02.64-4.38-.05-.99-.5-2.3-1.92-2.3-3.57v-57.32c0-1.54,1.18-2.9,2.07-3.43,1.4-.83,3.15-1.02,4.61-.19l49.5,28.35c1.53.88,2.28,2.42,2.28,3.93s-.75,3.05-2.28,3.93Z"/>
            </svg>
            <p class="text-sm leading-relaxed text-[var(--text-muted)]">Primary Text <span class="font-mono">#1c1c1e</span> on white or Warm Canvas</p>
          </div>
        </div>
        <div class="rounded-[20px] border border-[#3a3a3e] bg-[#1c1c1e] p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#a8a49b]">Mark — Dark Background</p>
          <div class="mt-4 flex items-center gap-4">
            <svg class="h-10 w-auto shrink-0" fill="#f7f4ee" viewBox="0 0 155 159" xmlns="http://www.w3.org/2000/svg" aria-label="ForWorship mark">
              <path d="M81.75,0c26.54,2.56,50,18.25,61.69,41.76,13.03,26.19,10.03,56.63-7.1,79.62l5.9,33.47c.35,1.99-1.31,3.09-2.45,4.15h-2.55l-33.92-12.5c-23.51,9.02-49.37,6.22-70.42-8.1C14.21,125.68,2.2,104.73,0,81.75v-12C3.78,32.19,32.19,3.73,69.75,0h12ZM138.28,75.7c0-34.34-27.84-62.18-62.18-62.18S13.93,41.36,13.93,75.7s27.84,62.18,62.18,62.18,62.18-27.84,62.18-62.18Z"/>
              <path d="M112.18,79.73l-49.5,28.35c-1.35.77-3.02.64-4.38-.05-.99-.5-2.3-1.92-2.3-3.57v-57.32c0-1.54,1.18-2.9,2.07-3.43,1.4-.83,3.15-1.02,4.61-.19l49.5,28.35c1.53.88,2.28,2.42,2.28,3.93s-.75,3.05-2.28,3.93Z"/>
            </svg>
            <p class="text-sm leading-relaxed text-[#a8a49b]">Warm Canvas <span class="font-mono">#f7f4ee</span> on dark backgrounds</p>
          </div>
        </div>
      </div>
      <div class="mt-4 rounded-[20px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--text-muted)]">Implementation Note</p>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-body)]">
          Logo assets are at <span class="font-mono">resources/fw_logo_horiz_dark.svg</span> (horizontal, primary) and <span class="font-mono">resources/fw_logo_vert_dark.svg</span> (vertical). In the application, both are inlined as SVG with <span class="font-mono">fill="currentColor"</span> — color adapts via CSS without separate light/dark files. The mark-only version for the collapsed sidebar is achieved by cropping the horizontal SVG to <span class="font-mono">viewBox="0 0 155 159"</span>.
        </p>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Core Palette</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Warm neutrals with restrained anchors
      </h2>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--text-muted)]">
        The core palette carries the everyday product atmosphere. Most interfaces should stay here and let accent colors step in only when hierarchy, emotion, or status needs help.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {corePalette.map((token) => (
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-4" style="box-shadow: var(--shadow-1);">
            <div class="h-24 rounded-[16px] border border-black/5" style={`background:${token.hex};`}></div>
            <div class="mt-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-semibold text-[var(--text-strong)]">{token.name}</h3>
                <span class="rounded-full bg-[var(--surface-soft)] px-3 py-1 text-xs font-semibold text-[var(--text-muted)]">{token.hex}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{token.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Supporting Accents</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Additional accents, not additional primaries
      </h2>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--text-muted)]">
        These colors support hierarchy, emotion, and clarity. They should feel like worn brass, clay, and quiet depth — not a rainbow interface.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {supportingPalette.map((token) => (
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-4" style="box-shadow: var(--shadow-1);">
            <div class="h-24 rounded-[16px] border border-black/5" style={`background:${token.hex};`}></div>
            <div class="mt-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-semibold text-[var(--text-strong)]">{token.name}</h3>
                <span class="rounded-full bg-[var(--surface-soft)] px-3 py-1 text-xs font-semibold text-[var(--text-muted)]">{token.hex}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-body)]">{token.usage}</p>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{token.role}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Semantic Color</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Calm status, not alarm theatre
        </h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {semanticCards.map((card) => (
            <div class={`rounded-[20px] border p-5 ${card.className}`} style="box-shadow: var(--shadow-1);">
              <div class="flex items-center justify-between gap-3">
                <p class="text-base font-semibold text-[var(--text-strong)]">{card.label}</p>
                <span class={`rounded-full px-3 py-1 text-xs font-semibold ${card.chipClass}`}>{card.label}</span>
              </div>
              <p class="mt-2 text-sm text-[var(--text-muted)]">{card.tone}</p>
              <p class="mt-4 text-sm leading-relaxed text-[var(--text-body)]">{card.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Color Restraint</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Keep the interface mostly neutral
        </h2>
        <div class="mt-6 space-y-4">
          <div class="rounded-[20px] border border-[var(--accent-sky-border)] bg-[var(--accent-sky-soft)] p-4">
            <p class="text-sm font-semibold text-[var(--text-strong)]">Good</p>
            <p class="mt-2 text-sm leading-relaxed text-[var(--text-body)]">
              A mostly neutral screen with one calm accent is easier to scan, warmer to use, and clearer under pressure.
            </p>
          </div>
          <div class="rounded-[20px] border border-dashed border-[var(--accent-brick-border)] bg-white p-4">
            <p class="text-sm font-semibold text-[var(--text-strong)]">Avoid</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="rounded-full bg-[var(--accent-blue)] px-3 py-1 text-xs font-semibold text-white">Slate</span>
              <span class="rounded-full bg-[var(--accent-coral)] px-3 py-1 text-xs font-semibold text-white">Terracotta</span>
              <span class="rounded-full bg-[var(--accent-gold)] px-3 py-1 text-xs font-semibold text-[var(--text-strong)]">Gold</span>
              <span class="rounded-full bg-[var(--accent-sage)] px-3 py-1 text-xs font-semibold text-white">Olive</span>
              <span class="rounded-full bg-[var(--accent-plum)] px-3 py-1 text-xs font-semibold text-white">Mauve</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
              Do not turn dashboards into multicolor status walls. Use color to support meaning, not to decorate empty space.
            </p>
          </div>
        </div>
      </section>
    </div>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Neutral Layering</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Warm Canvas, Light Gray, and Surface working together
      </h2>
      <div class="mt-6 rounded-[28px] border border-[var(--color-soft-fog)] bg-[var(--color-warm-canvas)] p-5">
        <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="rounded-[22px] border border-[var(--color-soft-contrast)] bg-[var(--color-surface)] p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-sm font-semibold text-[var(--text-strong)]">Project Snapshot</p>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Surface card on Warm Canvas</p>
            <div class="mt-4 rounded-[16px] bg-[var(--color-soft-contrast)] p-4">
              <p class="text-sm text-[var(--text-body)]">Light Gray separates related information without feeling cold.</p>
            </div>
          </div>
          <div class="rounded-[22px] border border-[var(--color-soft-fog)] p-5" style="background: rgba(214, 210, 200, 0.18);">
            <div class="rounded-[18px] border border-[var(--color-soft-contrast)] bg-[var(--color-surface)] p-4">
              <div class="flex items-center justify-between gap-3">
                <p class="text-sm font-semibold text-[var(--text-strong)]">Layered Panel</p>
                <span class="rounded-full bg-[var(--color-soft-contrast)] px-3 py-1 text-xs font-semibold text-[var(--text-muted)]">Light Gray frame</span>
              </div>
              <div class="mt-4 space-y-3">
                <div class="h-3 rounded-full bg-[var(--color-soft-contrast)]"></div>
                <div class="h-3 w-4/5 rounded-full bg-[var(--color-soft-contrast)]"></div>
                <div class="h-3 w-3/5 rounded-full bg-[var(--color-soft-fog)]"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Example Usage</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Accent colors in small, purposeful moments
      </h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {accentExamples.map((item) => (
          <div class={`rounded-[20px] border p-5 ${item.className}`} style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--text-muted)]">{item.name}</p>
            <h3 class="mt-3 text-lg font-semibold text-[var(--text-strong)]">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--text-body)]">{item.copy}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Typography</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Editorial warmth with operational clarity
        </h2>
        <div class="mt-6 space-y-4">
          <div class="grid gap-4 xl:grid-cols-2">
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Fraunces</p>
              <p class="mt-3 text-4xl leading-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
                Let's get your team organized.
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Editorial brand voice for marketing headlines, page headlines, major section titles, onboarding headers, campaign titles, product storytelling, important empty states, and warmth moments.
              </p>
            </div>
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">IBM Plex Sans</p>
              <p class="mt-3 text-lg leading-tight text-[var(--text-body)]" style="font-family: var(--font-sans);">
                We'll walk through the essentials together and help shape your workspace around the way your church actually works.
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Operational workhorse for navigation, body copy, buttons, labels, forms, menus, tables, metadata, settings, dashboards, notifications, tasks, and dense information areas.
              </p>
            </div>
          </div>
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Working Together</p>
            <div class="mt-4 space-y-3">
              <p class="text-3xl leading-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
                Let's get your team organized.
              </p>
              <p class="text-base leading-relaxed text-[var(--text-body)]" style="font-family: var(--font-sans);">
                We'll walk through the essentials together and help shape your workspace around the way your church actually works.
              </p>
              <p class="text-2xl italic leading-snug text-[var(--accent-coral)]" style="font-family: var(--font-serif);">
                We'll help you figure it out.
              </p>
            </div>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-body)]">
                <span class="font-semibold text-[var(--text-strong)]">Fraunces</span><br />
                We understand. You're not alone.
              </div>
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-body)]">
                <span class="font-semibold text-[var(--text-strong)]">IBM Plex Sans</span><br />
                We can handle this.
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Spacing</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Room to breathe
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
          The system uses a 4px foundation with a working rhythm of 8, 12, 16, 24, 32, 48, and 64.
        </p>
        <div class="mt-6 space-y-3">
          {spacing.map((value) => (
            <div class="rounded-[18px] border border-[var(--border-soft)] bg-white px-4 py-3" style="box-shadow: var(--shadow-1);">
              <div class="flex items-center gap-4">
                <div class="h-4 rounded-full" style={`width:${value * 4}px; background: rgba(107, 114, 128, 0.2);`}></div>
                <div class="text-sm font-medium text-[var(--text-strong)]">{value}px</div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Radius</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Soft geometry
        </h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {radii.map((radius) => (
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-4" style="box-shadow: var(--shadow-1);">
              <div class:list={["h-20 border border-[var(--border-soft)] bg-[var(--surface-soft)]", radius.className]}></div>
              <div class="mt-4 flex items-center justify-between gap-3">
                <p class="font-semibold text-[var(--text-strong)]">{radius.label}</p>
                <span class="text-sm text-[var(--text-muted)]">{radius.value}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Shadows</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Soft atmospheric depth
        </h2>
        <div class="mt-6 space-y-4">
          {shadows.map((shadow) => (
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-[var(--page-bg)] p-4">
              <div class="rounded-[16px] bg-white p-5" style={shadow.style}>
                <div class="flex items-center justify-between gap-3">
                  <p class="font-semibold text-[var(--text-strong)]">{shadow.name}</p>
                  <span class="text-xs text-[var(--text-muted)]">Elevation sample</span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{shadow.value}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Component Personality</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Quietly capable interface parts
        </h2>

        <div class="mt-6 space-y-5">
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Buttons</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <button class="rounded-[10px] bg-[var(--accent-blue)] px-4 py-2.5 text-sm font-medium text-white" style="box-shadow: var(--shadow-1);">Start a project</button>
              <button class="rounded-[10px] border border-[var(--border-soft)] bg-white px-4 py-2.5 text-sm font-medium text-[var(--text-strong)]">Ask for approval</button>
              <button class="rounded-[10px] px-4 py-2.5 text-sm font-medium text-[var(--accent-coral)]" style="background: rgba(182, 94, 60, 0.10);">Need a quick note?</button>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">Cards</p>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
                <p class="text-sm font-semibold text-[var(--text-strong)]">Weekend Slide Set</p>
                <p class="mt-2 text-sm text-[var(--text-muted)]">Prepared and ready for reviewer approval before Thursday afternoon.</p>
              </div>
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
                <p class="text-sm font-semibold text-[var(--text-strong)]">Social Campaign</p>
                <p class="mt-2 text-sm text-[var(--text-muted)]">Three deliverables, one remaining approval, no urgent blockers right now.</p>
              </div>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Forms and Prompts</p>
            <div class="mt-4 rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
              <label class="text-sm font-medium text-[var(--text-strong)]">What would you like to share?</label>
              <div class="mt-3 rounded-[12px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-muted)]">
                Sunday announcement details, event timing, audience, and any files that would help.
              </div>
              <div class="mt-3 flex flex-wrap gap-2 text-sm">
                <span class="rounded-full px-3 py-1 text-[var(--accent-blue)]" style="background: rgba(107, 114, 128, 0.1);">Need a date</span>
                <span class="rounded-full px-3 py-1 text-[var(--accent-sage)]" style="background: rgba(132, 142, 108, 0.12);">Who is helping?</span>
                <span class="rounded-full px-3 py-1 text-[var(--accent-coral)]" style="background: rgba(182, 94, 60, 0.10);">Anything already drafted?</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">States and Guidance</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Supportive, steady communication
        </h2>

        <div class="mt-6 space-y-4">
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Empty State</p>
            <p class="mt-3 text-2xl text-[var(--text-strong)]" style="font-family: var(--font-serif);">Looks quiet in here. Want to plan something together?</p>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Empty states should invite momentum without sounding synthetic or overly cheerful.</p>
            <p class="mt-3 text-xl italic text-[var(--accent-sage)]" style="font-family: var(--font-serif);">We've got room to start this together.</p>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Notification Tone</p>
            <div class="mt-3 space-y-3">
              <div class="rounded-[16px] bg-[var(--surface-soft)] px-4 py-3 text-sm text-[var(--text-body)]">Looks like we still need a date for this before it can move forward.</div>
              <div class="rounded-[16px] bg-[var(--surface-soft)] px-4 py-3 text-sm text-[var(--text-body)]">Approval came through. This deliverable is clear for preparation and scheduling.</div>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">AI Suggestion</p>
            <div class="mt-3 rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
              <p class="text-sm font-medium text-[var(--text-strong)]">Quiet recommendation</p>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">
                This request sounds similar to last month's event promotion. Want me to pull that structure forward so you can edit instead of starting from scratch?
              </p>
              <p class="mt-3 text-xl italic text-[var(--accent-coral)]" style="font-family: var(--font-serif);">You don't have to start from zero.</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Dark Mode</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Warm late-night workspace
      </h2>
      <div class="mt-6 rounded-[24px] border border-[#3A3A3E] bg-[#1c1c1e] p-6 shadow-[0_12px_32px_rgba(10,14,18,0.26)]">
        <div class="grid gap-4 md:grid-cols-[0.8fr_1.2fr]">
          <div class="rounded-[20px] border border-white/10 bg-white/5 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#a0a8b0]">Dark Mode Direction</p>
            <p class="mt-3 text-2xl text-white" style="font-family: var(--font-serif);">
              Warm, calm, and readable.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">
              Base: <span class="font-mono">#1c1c1e</span>. Canvas: <span class="font-mono">#2a2a2d</span>. Avoid pure black, neon accents, and cyberpunk contrast. The mood should feel like focused evening work, not a control room.
            </p>
          </div>
          <div class="rounded-[20px] border border-white/10 bg-[#2a2a2d] p-5">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-white">Weekend service plan</p>
                <p class="mt-1 text-sm text-slate-300">Two approvals complete, one note still open.</p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-semibold text-[#96a082]" style="background: rgba(132, 142, 108, 0.2);">Steady</span>
            </div>
            <div class="mt-4 rounded-[16px] bg-white/5 p-4 text-sm leading-relaxed text-slate-300">
              Looks like the final social caption still needs review. Want me to bring the last approved version into view?
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</DocsLayout>
