---
import DocsLayout from "../../components/layout/DocsLayout.astro";

const palette = [
  { name: "Steady Blue", hex: "#4F6B7A", usage: "Primary brand emphasis, calm action states, structure." },
  { name: "Terracotta", hex: "#D9865B", usage: "Warm prompts, editorial accents, conversational warmth." },
  { name: "Sage", hex: "#7D9B87", usage: "Supportive moments, collaboration, calm secondary emphasis." },
  { name: "Main Canvas", hex: "#F7F6F3", usage: "Primary page background and workspace atmosphere." },
  { name: "Surface", hex: "#FFFFFF", usage: "Cards, forms, panels, and readable focus areas." },
  { name: "Soft Contrast", hex: "#ECE9E2", usage: "Dividers, quiet panels, subtle separation." },
  { name: "Primary Text", hex: "#2F3437", usage: "Headlines, strong labels, and readable interface text." },
  { name: "Secondary Text", hex: "#66707A", usage: "Supporting copy, metadata, and softer instructional text." },
];

const spacing = [8, 12, 16, 24, 32, 48, 64];

const radii = [
  { label: "Buttons", value: "10px", className: "rounded-[10px]" },
  { label: "Inputs", value: "12px", className: "rounded-[12px]" },
  { label: "Cards", value: "16px", className: "rounded-[16px]" },
  { label: "Modals", value: "20px", className: "rounded-[20px]" },
  { label: "Floating Panels", value: "24px", className: "rounded-[24px]" },
];

const shadows = [
  { name: "shadow-1", value: "0 1px 2px rgba(15, 23, 42, 0.04)", style: "box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);" },
  { name: "shadow-2", value: "0 4px 12px rgba(15, 23, 42, 0.06)", style: "box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);" },
  { name: "shadow-3", value: "0 12px 32px rgba(15, 23, 42, 0.10)", style: "box-shadow: 0 12px 32px rgba(15, 23, 42, 0.10);" },
];
---

<DocsLayout
  title="Visual System | wegotthis.online Docs"
  description="Visual brand system for the calm editorial workspace direction."
>
  <div class="space-y-6">
    <section class="docs-card p-8 md:p-10">
      <p class="eyebrow">Visual System</p>
      <div class="mt-4 max-w-4xl">
        <h1 class="text-4xl tracking-tight text-[var(--text-strong)] md:text-5xl" style="font-family: var(--font-serif);">
          Calm Editorial Workspace
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-[var(--text-muted)]">
          wegotthis should feel like a calm, capable teammate in visual form: clear, warm, steady, and ready to help without becoming loud, cold, or managerial.
        </p>
        <div class="mt-6 rounded-[24px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-6" style="box-shadow: var(--shadow-2);">
          <p class="text-sm leading-relaxed text-[var(--text-body)]" style="font-family: var(--font-serif);">
            "The interface should feel like a thoughtfully designed creative workspace before the team arrives: morning light, calm order, quiet readiness, and the sense that someone capable is already helping."
          </p>
        </div>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="eyebrow">Brand Feeling</p>
          <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
            Calm, support, clarity, warmth, confidence, collaboration
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed text-[var(--text-muted)]">
          The system should avoid dense enterprise dashboards, harsh admin UI, church clipart energy, productivity-bro aesthetics, overhyped startup styling, and gimmicky AI visuals.
        </p>
      </div>
    </section>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Color System</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Warm neutrals with restrained accents
      </h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {palette.map((token) => (
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-4" style="box-shadow: var(--shadow-1);">
            <div class="h-24 rounded-[16px] border border-black/5" style={`background:${token.hex};`}></div>
            <div class="mt-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-semibold text-[var(--text-strong)]">{token.name}</h3>
                <span class="rounded-full bg-[var(--surface-soft)] px-3 py-1 text-xs font-semibold text-[var(--text-muted)]">{token.hex}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{token.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Typography</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Editorial warmth with operational clarity
        </h2>
        <div class="mt-6 space-y-4">
          <div class="grid gap-4 xl:grid-cols-3">
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">IBM Plex Serif</p>
              <p class="mt-3 text-4xl leading-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
                Let's get your team organized.
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Editorial brand voice for marketing headlines, page headlines, major section titles, onboarding headers, campaign titles, product storytelling, and important empty states.
              </p>
            </div>
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">IBM Plex Sans</p>
              <p class="mt-3 text-lg leading-relaxed text-[var(--text-body)]" style="font-family: var(--font-sans);">
                We'll walk through the essentials together and help shape your workspace around the way your church actually works.
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Operational workhorse for navigation, body copy, buttons, labels, forms, menus, tables, metadata, settings, dashboards, notifications, tasks, and dense information areas.
              </p>
            </div>
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Caveat</p>
              <p class="font-hand mt-3 text-[22px] leading-tight text-[var(--accent-coral)]">
                We'll help you figure it out.
              </p>
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                Human accent layer for margin-note encouragement, onboarding reassurance, celebratory confirmations, subtle annotations, AI reassurance, and small "we got this" moments.
              </p>
            </div>
          </div>
          <div class="rounded-[20px] border border-[var(--accent-coral-border)] bg-[var(--accent-coral-soft)] p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Guidance</p>
            <p class="mt-3 text-sm leading-relaxed text-[var(--text-body)]">
              Caveat should feel discovered, not designed. Use it like a margin note, not a headline system.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
              Keep it regular weight, usually 14px to 24px, with tighter tracking around `-0.02em`, and in muted colors rather than high-contrast treatment.
            </p>
          </div>
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Working Together</p>
            <div class="mt-4 space-y-3">
              <p class="text-3xl leading-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
                Let's get your team organized.
              </p>
              <p class="text-base leading-relaxed text-[var(--text-body)]" style="font-family: var(--font-sans);">
                We'll walk through the essentials together and help shape your workspace around the way your church actually works.
              </p>
              <p class="font-hand text-[20px] leading-tight text-[var(--accent-sage)]">
                We'll help you figure it out.
              </p>
            </div>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-body)]">
                <span class="font-semibold text-[var(--text-strong)]">IBM Plex Serif</span><br />
                We understand.
              </div>
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-body)]">
                <span class="font-semibold text-[var(--text-strong)]">IBM Plex Sans</span><br />
                We can handle this.
              </div>
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-body)]">
                <span class="font-semibold text-[var(--text-strong)]">Caveat</span><br />
                You're not alone.
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Spacing</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Room to breathe
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
          The system uses a 4px foundation with a working rhythm of 8, 12, 16, 24, 32, 48, and 64.
        </p>
        <div class="mt-6 space-y-3">
          {spacing.map((value) => (
            <div class="rounded-[18px] border border-[var(--border-soft)] bg-white px-4 py-3" style="box-shadow: var(--shadow-1);">
              <div class="flex items-center gap-4">
                <div class="h-4 rounded-full" style={`width:${value * 4}px; background: rgba(79, 107, 122, 0.18);`}></div>
                <div class="text-sm font-medium text-[var(--text-strong)]">{value}px</div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Radius</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Soft geometry
        </h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {radii.map((radius) => (
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-4" style="box-shadow: var(--shadow-1);">
              <div class:list={["h-20 border border-[var(--border-soft)] bg-[var(--surface-soft)]", radius.className]}></div>
              <div class="mt-4 flex items-center justify-between gap-3">
                <p class="font-semibold text-[var(--text-strong)]">{radius.label}</p>
                <span class="text-sm text-[var(--text-muted)]">{radius.value}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Shadows</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Soft atmospheric depth
        </h2>
        <div class="mt-6 space-y-4">
          {shadows.map((shadow) => (
            <div class="rounded-[20px] border border-[var(--border-soft)] bg-[var(--page-bg)] p-4">
              <div class="rounded-[16px] bg-white p-5" style={shadow.style}>
                <div class="flex items-center justify-between gap-3">
                  <p class="font-semibold text-[var(--text-strong)]">{shadow.name}</p>
                  <span class="text-xs text-[var(--text-muted)]">Elevation sample</span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">{shadow.value}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">Component Personality</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Quietly capable interface parts
        </h2>

        <div class="mt-6 space-y-5">
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Buttons</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <button class="rounded-[10px] bg-[var(--accent-blue)] px-4 py-2.5 text-sm font-medium text-white" style="box-shadow: var(--shadow-1);">Start a project</button>
              <button class="rounded-[10px] border border-[var(--border-soft)] bg-white px-4 py-2.5 text-sm font-medium text-[var(--text-strong)]">Ask for approval</button>
              <button class="rounded-[10px] px-4 py-2.5 text-sm font-medium text-[var(--accent-coral)]" style="background: rgba(217, 134, 91, 0.12);">Need a quick note?</button>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">Cards</p>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
                <p class="text-sm font-semibold text-[var(--text-strong)]">Weekend Slide Set</p>
                <p class="mt-2 text-sm text-[var(--text-muted)]">Prepared and ready for stakeholder review before Thursday afternoon.</p>
              </div>
              <div class="rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
                <p class="text-sm font-semibold text-[var(--text-strong)]">Social Campaign</p>
                <p class="mt-2 text-sm text-[var(--text-muted)]">Three deliverables, one remaining approval, no urgent blockers right now.</p>
              </div>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Forms and Prompts</p>
            <div class="mt-4 rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
              <label class="text-sm font-medium text-[var(--text-strong)]">What would you like to share?</label>
              <div class="mt-3 rounded-[12px] border border-[var(--border-soft)] bg-white px-4 py-3 text-sm text-[var(--text-muted)]">
                Sunday announcement details, event timing, audience, and any files that would help.
              </div>
              <div class="mt-3 flex flex-wrap gap-2 text-sm">
                <span class="rounded-full px-3 py-1 text-[var(--accent-blue)]" style="background: rgba(79, 107, 122, 0.1);">Need a date</span>
                <span class="rounded-full px-3 py-1 text-[var(--accent-sage)]" style="background: rgba(125, 155, 135, 0.12);">Who is helping?</span>
                <span class="rounded-full px-3 py-1 text-[var(--accent-coral)]" style="background: rgba(217, 134, 91, 0.12);">Anything already drafted?</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-card p-6 md:p-8">
        <p class="eyebrow">States and Guidance</p>
        <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
          Supportive, steady communication
        </h2>

        <div class="mt-6 space-y-4">
          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-blue)]">Empty State</p>
            <p class="mt-3 text-2xl text-[var(--text-strong)]" style="font-family: var(--font-serif);">Looks quiet in here. Want to plan something together?</p>
            <p class="mt-2 text-sm text-[var(--text-muted)]">Empty states should invite momentum without sounding synthetic or overly cheerful.</p>
            <p class="font-hand mt-3 text-[18px] text-[var(--accent-sage)]">We've got room to start this together.</p>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-coral)]">Notification Tone</p>
            <div class="mt-3 space-y-3">
              <div class="rounded-[16px] bg-[var(--surface-soft)] px-4 py-3 text-sm text-[var(--text-body)]">Looks like we still need a date for this before it can move forward.</div>
              <div class="rounded-[16px] bg-[var(--surface-soft)] px-4 py-3 text-sm text-[var(--text-body)]">Approval came through. This deliverable is clear for preparation and scheduling.</div>
            </div>
          </div>

          <div class="rounded-[20px] border border-[var(--border-soft)] bg-white p-5" style="box-shadow: var(--shadow-1);">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent-sage)]">AI Suggestion</p>
            <div class="mt-3 rounded-[16px] border border-[var(--border-soft)] bg-[var(--surface-soft)] p-4">
              <p class="text-sm font-medium text-[var(--text-strong)]">Quiet recommendation</p>
              <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)]">
                This request sounds similar to last month's event promotion. Want me to pull that structure forward so you can edit instead of starting from scratch?
              </p>
              <p class="font-hand mt-3 text-[18px] text-[var(--accent-coral)]">You don't have to start from zero.</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <section class="docs-card p-6 md:p-8">
      <p class="eyebrow">Dark Mode</p>
      <h2 class="mt-3 text-3xl tracking-tight text-[var(--text-strong)]" style="font-family: var(--font-serif);">
        Warm late-night workspace
      </h2>
      <div class="mt-6 rounded-[24px] border border-[#3A4348] bg-[#23282C] p-6 shadow-[0_12px_32px_rgba(10,14,18,0.26)]">
        <div class="grid gap-4 md:grid-cols-[0.8fr_1.2fr]">
          <div class="rounded-[20px] border border-white/10 bg-white/5 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#B8C6CE]">Dark Mode Direction</p>
            <p class="mt-3 text-2xl text-white" style="font-family: var(--font-serif);">
              Warm, calm, and readable.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">
              Avoid pure black, neon accents, and cyberpunk contrast. The mood should feel like focused evening work, not a control room.
            </p>
          </div>
          <div class="rounded-[20px] border border-white/10 bg-[#2B3136] p-5">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-white">Weekend service plan</p>
                <p class="mt-1 text-sm text-slate-300">Two approvals complete, one note still open.</p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-semibold text-[#B9D1C0]" style="background: rgba(125, 155, 135, 0.2);">Steady</span>
            </div>
            <div class="mt-4 rounded-[16px] bg-white/5 p-4 text-sm leading-relaxed text-slate-300">
              Looks like the final social caption still needs review. Want me to bring the last approved version into view?
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</DocsLayout>
