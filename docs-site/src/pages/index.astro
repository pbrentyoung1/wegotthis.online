---
import DocsLayout from "../components/layout/DocsLayout.astro";
---

<DocsLayout title="wegotthis.online Docs" description="Internal architecture documentation for wegotthis.online.">
  <section class="docs-card p-8 md:p-10">
    <p class="eyebrow">Internal Docs</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-[var(--text-strong)] md:text-5xl">
      A calm architecture workspace for product and technical maps.
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-[var(--text-muted)]">
      This docs site is the lightweight internal layer for viewing map-based architecture work while GitHub remains the durable source of truth for decisions and documentation.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <a href="/architecture" class="docs-card-soft block p-5 transition hover:border-[var(--accent-blue)]">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--accent-blue)]">Architecture</p>
        <h2 class="mt-2 text-2xl font-semibold text-[var(--text-strong)]">Browse the map system</h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-body)]">
          View product architecture maps, technical architecture maps, and the placeholders for the next planning artifacts.
        </p>
      </a>

      <div class="docs-card-soft p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--accent-coral)]">Working Model</p>
        <h2 class="mt-2 text-2xl font-semibold text-[var(--text-strong)]">GitHub + Notion</h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-body)]">
          GitHub keeps the durable architecture layer. Notion stays focused on active execution, sprints, tasks, and coordination.
        </p>
      </div>
    </div>
  </section>
</DocsLayout>
