---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ActivityAuditRelationshipDiagram from "../../components/maps/ActivityAuditRelationshipDiagram";

const coreRules = [
  "Not every activity event is an audit log.",
  "Not every audit log belongs in visible product history.",
  "Audit logs should be immutable.",
  "Activity streams are user-facing and filterable.",
  "Notifications are downstream outcomes, not the system of record.",
];

const relationships = [
  "A user or system action may create an ActivityEvent.",
  "The same action may also create an AuditLog if security accountability matters.",
  "Notifications may be generated from activity or selected system events.",
  "Audit visibility should remain narrower than ordinary project history.",
];

const openQuestions = [
  "Which events should always create both activity and audit records?",
  "Which security-sensitive events should skip visible project history entirely?",
  "How much audit detail is necessary for the first pass without overbuilding?",
  "How should system-generated actions be labeled in user-facing history versus audit records?",
];

const relatedMaps = [
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
  { href: "/architecture/magic-link-scope", label: "External Access / Magic Link Scope" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
  { href: "/architecture/entity-relationship-diagram", label: "Entity Relationship Diagram" },
];
---

<DocsLayout title="Activity / Audit Relationship Diagram | ForWorship Creative Docs" description="Activity and audit relationship diagram.">
  <MapPage
    eyebrow="Technical Architecture"
    title="Activity / Audit Relationship Diagram"
    purpose="The split between visible work history and security-sensitive accountability records, plus how notifications relate to both."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ActivityAuditRelationshipDiagram slot="diagram" />
  </MapPage>
</DocsLayout>
