---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ProjectLifecycleMap from "../../components/maps/ProjectLifecycleMap";

const coreRules = [
  "Draft belongs to the request lifecycle, not the project lifecycle.",
  "Planned is a project status after approval and before active production.",
  "In Review can move into Revision when changes are required.",
  "Waiting for Approval belongs to deliverables or reviewable elements, not projects.",
  "Published does not equal done.",
  "Closeout is required before Archived.",
];

const relationships = [
  "Projects may begin as accepted requests.",
  "Project lifecycle must stay separate from request lifecycle.",
  "Deliverables can be in different states while the project stays at a higher-level status.",
  "Lifecycle changes should influence communication, notifications, and history.",
];

const openQuestions = [
  "Which transitions require explicit approval or confirmation?",
  "Which lifecycle changes should be visible to reviewers or external reviewers versus internal only?",
];

const relatedMaps = [
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
];
---

<DocsLayout title="Project Lifecycle | ForWorship Creative Docs" description="Project lifecycle map for ForWorship Creative.">
  <MapPage
    title="Project Lifecycle"
    purpose="The project-level state model for moving work from intake through closeout and archive without flattening every deliverable into the same status."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ProjectLifecycleMap slot="diagram" />
  </MapPage>
</DocsLayout>
