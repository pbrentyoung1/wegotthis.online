---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ProductHierarchyMap from "../../components/maps/ProductHierarchyMap";

const coreRules = [
  "Campaign to Project is optional.",
  "Project to Deliverable is required.",
  "Deliverable to Task is required.",
  "Campaigns organize projects.",
  "Projects organize deliverables.",
  "Deliverables organize tasks.",
  "Tasks get the work done.",
];

const relationships = [
  "Campaigns may contain many projects.",
  "Projects may stand alone or belong to a campaign.",
  "Projects contain deliverables as the main production units.",
  "Tasks execute work within deliverable context.",
];

const openQuestions = [
  "Which supporting objects belong in the first version of the visual hierarchy?",
  "How much of the hierarchy should appear in first-pass navigation and dashboards?",
  "Which related objects should remain outside the core hierarchy map?",
];

const relatedMaps = [
  { href: "/architecture/project-lifecycle", label: "Project Lifecycle" },
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/entity-relationship-diagram", label: "Entity Relationship Diagram" },
];
---

<DocsLayout title="Product Hierarchy | ForWorship Creative Docs" description="The core product hierarchy for ForWorship Creative.">
  <MapPage
    title="Product Hierarchy"
    purpose="The foundational model for how work is organized in ForWorship Creative before deeper workflow and technical decisions are layered on top."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ProductHierarchyMap slot="diagram" />
  </MapPage>
</DocsLayout>
