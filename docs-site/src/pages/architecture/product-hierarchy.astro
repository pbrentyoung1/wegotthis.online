---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ProductHierarchyMap from "../../components/maps/ProductHierarchyMap";

const coreRules = [
  "Strategic Context is distinct from Operational Work.",
  "Campaigns and initiatives are optional strategic context.",
  "Programs / Content Streams are recurring operational rhythms.",
  "Project to Deliverable is required.",
  "Tasks belong to projects and may optionally belong to deliverables.",
  "Projects organize deliverables.",
  "Goal context flows into project and deliverable briefs.",
];

const relationships = [
  "Projects may associate with strategic context but do not have to.",
  "Projects preserve one primary operational home in MVP.",
  "Projects contain deliverables as the main production units.",
  "Deliverables must belong to projects.",
  "Tasks execute work within project or deliverable context.",
];

const openQuestions = [
  "Which strategic context entities should be first-class records in MVP?",
  "How much strategic context should appear in first-pass navigation and dashboards?",
  "Which related objects should remain outside the core structure map?",
];

const relatedMaps = [
  { href: "/architecture/project-lifecycle", label: "Project Lifecycle" },
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/entity-relationship-diagram", label: "Entity Relationship Diagram" },
];
---

<DocsLayout title="Product Structure | ForWorship Creative Docs" description="The core product structure for ForWorship Creative.">
  <MapPage
    title="Product Structure"
    purpose="The foundational model for how strategic context connects to operational work before deeper workflow and technical decisions are layered on top."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ProductHierarchyMap slot="diagram" />
  </MapPage>
</DocsLayout>
