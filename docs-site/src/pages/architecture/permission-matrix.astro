---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import PermissionMatrixMap from "../../components/maps/PermissionMatrixMap";

const coreRules = [
  "Permissions are tenant-scoped.",
  "Project roles may extend or narrow base roles in context.",
  "External reviewers only receive explicitly scoped magic-link permissions.",
  "Audit-log visibility should stay restricted.",
  "This is a first-pass matrix, not an exhaustive permission engine.",
];

const relationships = [
  "Roles shape what people can see, change, approve, or administer.",
  "Object-level context may widen or narrow what a base role can do.",
  "Magic-link access remains narrower than internal account access.",
  "Permission modeling affects workflow, data visibility, and audit behavior.",
];

const openQuestions = [
  "Which role distinctions are truly necessary for the first implementation pass?",
  "Where should project-level role overrides be strongest?",
  "Which actions need their own explicit permission versus inheriting from a broader capability?",
  "How much permission complexity can the product tolerate before it stops feeling calm?",
];

const relatedMaps = [
  { href: "/architecture/magic-link-scope", label: "External Access / Magic Link Scope" },
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
  { href: "/architecture/entity-relationship-diagram", label: "Entity Relationship Diagram" },
  { href: "/architecture/approval-flow", label: "Approval Flow" },
];
---

<DocsLayout title="Permission Matrix | wegotthis.online Docs" description="First-pass role and permission matrix.">
  <MapPage
    eyebrow="Technical Architecture"
    title="Permission Matrix"
    purpose="The first-pass matrix for who can perform which actions across settings, campaigns, projects, deliverables, tasks, approvals, assets, and magic-link workflows."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <PermissionMatrixMap slot="diagram" />
  </MapPage>
</DocsLayout>
