---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import MagicLinkScopeMap from "../../components/maps/MagicLinkScopeMap";

const coreRules = [
  "Magic links do not grant broad project access.",
  "Links should be revocable and time-bound.",
  "All actions taken through a link should be logged.",
  "Permissions are explicit rather than inherited casually.",
  "Magic links support people who should not need full accounts.",
];

const relationships = [
  "An internal user generates a scoped link.",
  "The system validates token, expiration, permissions, and scope before access.",
  "Reviewers can only take the actions explicitly granted to the link.",
  "Link usage feeds audit visibility and external review history.",
];

const openQuestions = [
  "Which external personas should be allowed to upload files in the first version?",
  "When should optional identity capture be required versus optional?",
  "Should some links expose full deliverable context while others expose only a version?",
  "How should expired links be presented to keep the experience graceful without weakening security?",
];

const relatedMaps = [
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Magic Link Scope | wegotthis.online Docs" description="External access and magic-link scope map.">
  <MapPage
    title="External Access / Magic Link Scope Map"
    purpose="The scoped access model that lets external reviewers and lightweight collaborators interact with work without creating full accounts."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <MagicLinkScopeMap slot="diagram" />
  </MapPage>
</DocsLayout>
