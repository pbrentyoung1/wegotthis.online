---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";

const expectedQuestions = [
  "What should a stakeholder see versus a vendor?",
  "Which actions can be taken through a magic link?",
  "How narrow should project versus deliverable access be?",
  "Which file, comment, and approval details should remain hidden externally?",
];

const relatedMaps = [
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Magic Link Scope | wegotthis.online Docs" description="Placeholder page for the external access and magic link scope map.">
  <MapPage
    title="External Access / Magic Link Scope Map"
    purpose="This map will define what external stakeholders and vendors can see and do through scoped, time-bound access links."
    status="Not yet created"
    coreRules={["External access should be narrow, revocable, and calm by default."]}
    relationships={["This map will connect approvals, files, comments, permissions, and audit expectations."]}
    expectedQuestions={expectedQuestions}
    relatedMaps={relatedMaps}
  >
    <div slot="diagram" class="flex min-h-[240px] items-center justify-center bg-[var(--surface-soft)] p-8 text-center">
      <div class="docs-card-soft max-w-xl px-6 py-8">
        <p class="eyebrow">Placeholder</p>
        <h2 class="mt-3 text-2xl font-semibold text-[var(--text-strong)]">Status: Not yet created</h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
          This page is reserved for the external access scope model and magic link review boundaries.
        </p>
      </div>
    </div>
  </MapPage>
</DocsLayout>
