---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ExternalAccessMagicLinkScopeMap from "../../components/maps/ExternalAccessMagicLinkScopeMap";

const coreRules = [
  "Magic links do not grant general tenant access.",
  "Links are tenant-bound, scope-bound, time-bound, and revocable.",
  "Allowed actions are explicit and should not be inherited casually.",
  "External access should reduce friction without creating unnecessary accounts.",
  "Link usage should create communication, activity, audit, approval, and notification records where appropriate.",
];

const relationships = [
  "Communications Lead, Project Owner, or another authorized internal user generates the link.",
  "The system binds the link to tenant, project, deliverable or approval context, recipient, and allowed actions.",
  "External Reviewer access stays limited to the shared item and explicit permissions.",
  "When the reviewer acts, the system updates project history, approval state, and internal notifications.",
];

const openQuestions = [
  "Which External Reviewer scenarios should allow selected file upload in MVP?",
  "When should recipient identity capture be required versus optional?",
  "Should some links expose only approval context while others expose a broader project summary?",
  "How should expired or superseded links be presented without weakening security or creating confusion?",
];

const relatedMaps = [
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Magic Link Scope | ForWorship Creative Docs" description="External access and magic-link scope map.">
  <MapPage
    title="External Access / Magic Link Scope Map"
    purpose="The canonical external-access model for scoped review, approval, and limited participation without granting general tenant access or creating unnecessary full accounts."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ExternalAccessMagicLinkScopeMap slot="diagram" />
  </MapPage>
</DocsLayout>
