---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import DeliverableLifecycleMap from "../../components/maps/DeliverableLifecycleMap";

const coreRules = [
  "Deliverables may have their own status independent of project status.",
  "Approval logic primarily belongs to deliverables.",
  "Waiting for Approval belongs to deliverables or reviewable elements.",
  "Changes Requested belongs to deliverable review loops.",
  "Deliverables should not force the whole project backward automatically.",
];

const relationships = [
  "Deliverables live inside projects but move through their own more detailed states.",
  "Approvals primarily attach to deliverables in MVP.",
  "Project Revision reflects one or more deliverables needing changes.",
  "Deliverable state changes should influence project visibility and communication history.",
];

const openQuestions = [
  "How should revision loops be represented without overcomplicating the model?",
  "Which deliverable events should create notifications versus just history entries?",
];

const relatedMaps = [
  { href: "/architecture/project-lifecycle", label: "Project Lifecycle" },
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
];
---

<DocsLayout title="Deliverable Lifecycle | ForWorship Creative Docs" description="Deliverable lifecycle map for ForWorship Creative.">
  <MapPage
    title="Deliverable Lifecycle"
    purpose="The production and publication model for deliverables, where review, approval, scheduling, and publication need more precision than project status alone."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <DeliverableLifecycleMap slot="diagram" />
  </MapPage>
</DocsLayout>
