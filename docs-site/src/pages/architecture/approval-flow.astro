---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";

const expectedQuestions = [
  "Who can request approval, approve, reject, or request changes?",
  "Which approval states are required for MVP?",
  "How should internal review differ from external review?",
  "When should approval events affect deliverable status or project visibility?",
];

const relatedMaps = [
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/magic-link-scope", label: "External Access / Magic Link Scope" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
];
---

<DocsLayout title="Approval Flow | wegotthis.online Docs" description="Placeholder page for the approval flow map.">
  <MapPage
    title="Approval Flow Map"
    purpose="This map will describe how review, approval, rejection, requested changes, and reopening should move through the system."
    status="Not yet created"
    coreRules={["Approvals should remain calm, understandable, and centered on deliverables for MVP."]}
    relationships={["This map will connect lifecycle states, external access, permissions, and notifications."]}
    expectedQuestions={expectedQuestions}
    relatedMaps={relatedMaps}
  >
    <div slot="diagram" class="flex min-h-[240px] items-center justify-center bg-[var(--surface-soft)] p-8 text-center">
      <div class="docs-card-soft max-w-xl px-6 py-8">
        <p class="eyebrow">Placeholder</p>
        <h2 class="mt-3 text-2xl font-semibold text-[var(--text-strong)]">Status: Not yet created</h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
          This page is reserved for the approval flow map once the lifecycle and permission decisions are tighter.
        </p>
      </div>
    </div>
  </MapPage>
</DocsLayout>
