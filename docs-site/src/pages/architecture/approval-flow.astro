---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import ApprovalFlowMap from "../../components/maps/ApprovalFlowMap";

const coreRules = [
  "Approvals usually happen on deliverables, not entire projects.",
  "Review can loop backward into production.",
  "Approval records should capture who approved, when, and what version.",
  "External reviewers may participate through magic links.",
  "Approval clears a deliverable for fulfillment but does not equal completion.",
];

const relationships = [
  "Creators submit deliverables into review.",
  "Internal review can lead to additional review or send work back for changes.",
  "External Reviewer participation may happen through scoped external access.",
  "Final approval moves work toward scheduled and published states.",
];

const openQuestions = [
  "Which deliverables require only internal approval versus external review?",
  "How many revision loops should the first implementation support gracefully?",
  "Which approval steps must be captured in the activity stream versus the audit log?",
  "Should some approvals be bypassable by trusted internal roles?",
];

const relatedMaps = [
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/magic-link-scope", label: "External Access / Magic Link Scope" },
  { href: "/architecture/notification-trigger", label: "Notification Trigger" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
];
---

<DocsLayout title="Approval Flow | ForWorship Creative Docs" description="Approval flow map for deliverable review and approval.">
  <MapPage
    title="Approval Flow Map"
    purpose="The review path that moves a deliverable from internal review through optional additional review and into scheduling or publication readiness."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <ApprovalFlowMap slot="diagram" />
  </MapPage>
</DocsLayout>
