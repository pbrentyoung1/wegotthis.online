---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";

const expectedQuestions = [
  "Which events should trigger immediate notifications?",
  "Which events should stay visible only in project history?",
  "Which notifications should be digest-based instead of immediate?",
  "How should preferences modify delivery without changing source events?",
];

const relatedMaps = [
  { href: "/architecture/project-lifecycle", label: "Project Lifecycle" },
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Notification Trigger | wegotthis.online Docs" description="Placeholder page for the notification trigger map.">
  <MapPage
    title="Notification Trigger Map"
    purpose="This map will clarify which system events should create notifications and which should remain context-only without adding noise."
    status="Not yet created"
    coreRules={["Notifications should support action, not activity theater."]}
    relationships={["This map will connect lifecycle changes, approvals, comments, permissions, and user preferences."]}
    expectedQuestions={expectedQuestions}
    relatedMaps={relatedMaps}
  >
    <div slot="diagram" class="flex min-h-[240px] items-center justify-center bg-[var(--surface-soft)] p-8 text-center">
      <div class="docs-card-soft max-w-xl px-6 py-8">
        <p class="eyebrow">Placeholder</p>
        <h2 class="mt-3 text-2xl font-semibold text-[var(--text-strong)]">Status: Not yet created</h2>
        <p class="mt-3 text-sm leading-relaxed text-[var(--text-muted)]">
          This page will become the notification trigger reference once the first event map is documented.
        </p>
      </div>
    </div>
  </MapPage>
</DocsLayout>
