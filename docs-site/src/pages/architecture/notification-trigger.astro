---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import NotificationTriggerMap from "../../components/maps/NotificationTriggerMap";

const coreRules = [
  "Not every event should create a notification.",
  "Urgency helps determine the channel.",
  "User preferences change delivery behavior.",
  "Audit events are not always notifications.",
  "Notifications should point back to the relevant object and context.",
];

const relationships = [
  "System events feed trigger rules.",
  "Trigger rules resolve audience and channel strategy.",
  "Delivery can be immediate, batched, or suppressed by preference.",
  "Notification outcomes should be logged without replacing source events.",
];

const openQuestions = [
  "Which events should always notify immediately versus wait for digest treatment?",
  "Which audiences should inherit notifications versus explicitly subscribe?",
  "How should future push or SMS channels differ from email and in-app delivery?",
  "Which technical events belong only in audit history instead of user-facing notifications?",
];

const relatedMaps = [
  { href: "/architecture/project-lifecycle", label: "Project Lifecycle" },
  { href: "/architecture/deliverable-lifecycle", label: "Deliverable Lifecycle" },
  { href: "/architecture/approval-flow", label: "Approval Flow" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Notification Trigger | ForWorship Creative Docs" description="Notification trigger map for event-driven delivery.">
  <MapPage
    title="Notification Trigger Map"
    purpose="The event-to-delivery model that decides when the system should notify people, who should hear about it, and how it should be sent."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <NotificationTriggerMap slot="diagram" />
  </MapPage>
</DocsLayout>
