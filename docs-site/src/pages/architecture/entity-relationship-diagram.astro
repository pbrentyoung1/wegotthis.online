---
import DocsLayout from "../../components/layout/DocsLayout.astro";
import MapPage from "../../components/layout/MapPage.astro";
import EntityRelationshipDiagram from "../../components/maps/EntityRelationshipDiagram";

const coreRules = [
  "This is a conceptual ERD, not the final database schema.",
  "Organization is the tenant boundary.",
  "Membership connects users to organizations.",
  "The product hierarchy drives core work relationships.",
  "Activity and audit are related but distinct concepts.",
];

const relationships = [
  "Identity and access entities support organization-scoped membership.",
  "Campaign, project, deliverable, and task define the work backbone.",
  "Assets, approvals, and magic links connect fulfillment and external access behavior.",
  "Comments, notifications, activity, and audit shape product history and security traceability.",
];

const openQuestions = [
  "Which conceptual entities should be present in the first scaffold versus deferred?",
  "Which relationships need explicit history tables or state logs later?",
  "How should polymorphic comment or activity behavior be modeled without obscuring the concept map?",
  "Where should the ERD stay intentionally conceptual rather than drifting into premature schema design?",
];

const relatedMaps = [
  { href: "/architecture/product-hierarchy", label: "Product Hierarchy" },
  { href: "/architecture/permission-matrix", label: "Permission Matrix" },
  { href: "/architecture/activity-audit-relationship-diagram", label: "Activity / Audit Relationship Diagram" },
];
---

<DocsLayout title="Entity Relationship Diagram | ForWorship Creative Docs" description="Conceptual entity relationship diagram.">
  <MapPage
    eyebrow="Technical Architecture"
    title="Entity Relationship Diagram"
    purpose="The conceptual data model that connects identity, work structure, assets, approvals, notifications, magic links, activity, and audit behavior."
    coreRules={coreRules}
    relationships={relationships}
    openQuestions={openQuestions}
    relatedMaps={relatedMaps}
  >
    <EntityRelationshipDiagram slot="diagram" />
  </MapPage>
</DocsLayout>
